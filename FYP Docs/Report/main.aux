\newlabel{tab:oos_spread_stats}{{5.3}{26}{Spread statistics across in-sample (IS: January 2019 -- December 2023) and out-of-sample (OOS: January 2024 -- December 2025) periods, constructed using in-sample hedge ratios.\\}{table.5.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5.4}{\ignorespaces Cointegration validation statistics across IS (January 2019 -- December 2023) and OOS (January 2024 -- December 2025) periods. ADF $p$-values below 0.05 indicate spread stationarity at the 5\% significance level. Half-life below 60 trading days and Hurst exponent below 0.5 indicate mean reversion.\\}}{26}{table.5.4}\protected@file@percent }
\newlabel{tab:cointegration_validation}{{5.4}{26}{Cointegration validation statistics across IS (January 2019 -- December 2023) and OOS (January 2024 -- December 2025) periods. ADF $p$-values below 0.05 indicate spread stationarity at the 5\% significance level. Half-life below 60 trading days and Hurst exponent below 0.5 indicate mean reversion.\\}{table.5.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.6}{\ignorespaces IS vs OOS Engle-Granger $p$-values for all 16 sector-candidate pairs. Panel labels (a)--(p) correspond to the pairs listed in Table\nobreakspace  {}\ref {tab:cointegration_screening}. Hatched bars indicate pairs that fail the 5\% significance threshold. Of the three pairs that pass IS screening, GS/MS and KO/PEP remain the most stable OOS; DAL/UAL degrades substantially. The remaining 13 pairs show no evidence of cointegration in either period.}}{27}{figure.5.6}\protected@file@percent }
\newlabel{fig:oos_eg_pvalues}{{5.6}{27}{IS vs OOS Engle-Granger $p$-values for all 16 sector-candidate pairs. Panel labels (a)--(p) correspond to the pairs listed in Table~\ref {tab:cointegration_screening}. Hatched bars indicate pairs that fail the 5\% significance threshold. Of the three pairs that pass IS screening, GS/MS and KO/PEP remain the most stable OOS; DAL/UAL degrades substantially. The remaining 13 pairs show no evidence of cointegration in either period}{figure.5.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.7}{\ignorespaces Spread levels across the full sample period (January 2019 -- December 2025). The dashed vertical line marks the IS/OOS boundary (January 2024). Horizontal lines and shading denote IS $\pm 1\sigma $ and $\pm 2\sigma $ bands; persistent OOS displacement beyond these bounds indicates a structural break in the cointegrating relationship. (a)\nobreakspace  {}KO/PEP; (b)\nobreakspace  {}GS/MS; (c)\nobreakspace  {}DAL/UAL.}}{28}{figure.5.7}\protected@file@percent }
\newlabel{fig:spread_is_oos_concat}{{5.7}{28}{Spread levels across the full sample period (January 2019 -- December 2025). The dashed vertical line marks the IS/OOS boundary (January 2024). Horizontal lines and shading denote IS $\pm 1\sigma $ and $\pm 2\sigma $ bands; persistent OOS displacement beyond these bounds indicates a structural break in the cointegrating relationship. (a)~KO/PEP; (b)~GS/MS; (c)~DAL/UAL}{figure.5.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.8}{\ignorespaces Rolling 60-day $z$-score across the full sample period (January 2019 -- December 2025). The dashed vertical line marks the IS/OOS boundary. Shaded regions indicate $|z|>2\sigma $ exceedances. Persistent non-zero $z$-scores in the OOS period are consistent with a shift in the spread equilibrium level. (a)\nobreakspace  {}KO/PEP; (b)\nobreakspace  {}GS/MS; (c)\nobreakspace  {}DAL/UAL.}}{29}{figure.5.8}\protected@file@percent }
\newlabel{fig:zscore_is_oos}{{5.8}{29}{Rolling 60-day $z$-score across the full sample period (January 2019 -- December 2025). The dashed vertical line marks the IS/OOS boundary. Shaded regions indicate $|z|>2\sigma $ exceedances. Persistent non-zero $z$-scores in the OOS period are consistent with a shift in the spread equilibrium level. (a)~KO/PEP; (b)~GS/MS; (c)~DAL/UAL}{figure.5.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.9}{\ignorespaces Rolling half-life of mean reversion across the full sample period (January 2019 -- December 2025). Faint lines show raw estimates; bold lines show 21-day exponentially weighted smoothed values. The dashed horizontal line marks the 60-day tradability threshold. The dashed vertical line marks the IS/OOS boundary. (a)\nobreakspace  {}KO/PEP; (b)\nobreakspace  {}GS/MS; (c)\nobreakspace  {}DAL/UAL.}}{30}{figure.5.9}\protected@file@percent }
\newlabel{fig:rolling_halflife_is_oos}{{5.9}{30}{Rolling half-life of mean reversion across the full sample period (January 2019 -- December 2025). Faint lines show raw estimates; bold lines show 21-day exponentially weighted smoothed values. The dashed horizontal line marks the 60-day tradability threshold. The dashed vertical line marks the IS/OOS boundary. (a)~KO/PEP; (b)~GS/MS; (c)~DAL/UAL}{figure.5.9}{}}
